# ============================================================================
# OpenClaw Proxmox Deployment Konfiguration
# ============================================================================
# Kopiere diese Datei zu .env und passe die Werte an:
# cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Proxmox Verbindung
# ----------------------------------------------------------------------------

# IP-Adresse oder Hostname des Proxmox-Hosts
PROXMOX_HOST=192.168.1.4

# SSH-Benutzer (normalerweise root)
PROXMOX_USER=root

# SSH-Port (Standard: 22)
PROXMOX_PORT=22

# Authentifizierungsmethode: "key", "password" oder "auto"
# - "key": Nur SSH-Key-basierte Authentifizierung
# - "password": Nur Passwort-Authentifizierung (erfordert sshpass)
# - "auto": SSH-Key mit Passwort-Fallback (empfohlen)
PROXMOX_AUTH_METHOD=auto

# Root-Passwort für Fallback oder Passwort-Auth
# ACHTUNG: .env ist in .gitignore - trotzdem sensible Daten!
# Für Passwort-Auth/Fallback: Installiere sshpass (sudo apt install sshpass)
PROXMOX_PASSWORD=

# ===== Beispiel-Konfigurationen =====
#
# Variante A: SSH-Key mit Passwort-Fallback (Empfohlen)
#   PROXMOX_AUTH_METHOD=auto
#   PROXMOX_PASSWORD=DeinRootPasswort
#   Setup: ssh-keygen -t ed25519 && ssh-copy-id root@192.168.1.4
#   Verhalten: Versucht erst SSH-Key, bei Fehler Passwort
#
# Variante B: Nur SSH-Key (Maximale Sicherheit)
#   PROXMOX_AUTH_METHOD=key
#   # PROXMOX_PASSWORD bleibt leer
#   Setup: ssh-keygen -t ed25519 && ssh-copy-id root@192.168.1.4
#
# Variante C: Nur Passwort (Schneller Setup)
#   PROXMOX_AUTH_METHOD=password
#   PROXMOX_PASSWORD=DeinRootPasswort
#   Setup: sudo apt install sshpass
#
# Siehe: docs/SSH-AUTH.md für Details

# ----------------------------------------------------------------------------
# LXC Container Konfiguration
# ----------------------------------------------------------------------------

# Container ID (wird automatisch erhöht falls belegt)
LXC_ID=111

# Hostname des Containers
LXC_HOSTNAME=openclaw-agents

# CPU Cores
LXC_CORES=4

# RAM in MB
LXC_MEMORY=8192

# Swap in MB
LXC_SWAP=2048

# Root-Filesystem Größe in GB
LXC_ROOTFS=40

# Storage für Container (z.B. local-lvm, local-zfs)
LXC_STORAGE=local-lvm

# ----------------------------------------------------------------------------
# Netzwerk Konfiguration
# ----------------------------------------------------------------------------

# Netzwerk-Bridge (Standard: vmbr0)
LXC_NETWORK_BRIDGE=vmbr0

# IP-Konfiguration:
# - "dhcp" für automatische IP-Zuweisung
# - "192.168.1.11/24" für statische IP
LXC_NETWORK_IP="192.168.1.11/24"

# Gateway (nur bei statischer IP erforderlich)
LXC_GATEWAY="192.168.1.1"

# ----------------------------------------------------------------------------
# OS Template
# ----------------------------------------------------------------------------

# Storage für Templates (meist "local")
TEMPLATE_STORAGE=local

# Template Name (Ubuntu 24.04 LTS empfohlen)
TEMPLATE_NAME=ubuntu-24.04-standard

# ----------------------------------------------------------------------------
# SSH Keys (optional)
# ----------------------------------------------------------------------------

# Public SSH Key für Container-Zugriff
# Wird automatisch in /root/.ssh/authorized_keys eingefügt
SSH_PUBLIC_

# ----------------------------------------------------------------------------
# OpenClaw Konfiguration
# ----------------------------------------------------------------------------

# ===== Option A: Native Claude API (empfohlen für später) =====
# Von https://console.anthropic.com/
CLAUDE_API_KEY=

# ===== Option B: Amazon Bedrock (aktuell) =====
# AWS Credentials für Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# LiteLLM Proxy (übersetzt Bedrock → Anthropic API Format)
# Wird automatisch installiert wenn AWS_ACCESS_KEY_ID gesetzt ist
LITELLM_ENABLED=true
LITELLM_PORT=4000

# ===== Weitere Integrationen =====

# GitHub Token (für Review-Agent)
# Von https://github.com/settings/tokens
GITHUB_TOKEN=

# Discord Bot Token (für Agent-Steuerung via Discord)
# Von https://discord.com/developers/applications
DISCORD_TOKEN=

# ----------------------------------------------------------------------------
# Traefik Remote Server (für Ops-Agent)
# ----------------------------------------------------------------------------

# Hostname oder IP des Traefik-Servers
# Wenn Traefik auf dem Proxmox-Host läuft: Proxmox-IP verwenden
TRAEFIK_HOST=192.168.1.4

# SSH-Port des Traefik-Servers
TRAEFIK_SSH_PORT=22

# SSH-Benutzer auf Traefik-Server
TRAEFIK_SSH_USER=root

# Pfad zu Traefik-Config auf Remote-Server
# Bei Docker-Installation meist: /docker/volume/traefik/config oder /opt/traefik
TRAEFIK_CONFIG_PATH=/docker/volume/traefik/config

# Docker-Container Name (falls Traefik als Container läuft)
TRAEFIK_CONTAINER_NAME=traefik

# Traefik läuft als Docker Container (true/false)
TRAEFIK_IS_DOCKER=true

# ----------------------------------------------------------------------------
# Erweiterte Optionen
# ----------------------------------------------------------------------------

# Auto-Start Container bei Proxmox-Boot
LXC_ONBOOT=1

# Unprivileged Container (empfohlen: 1)
LXC_UNPRIVILEGED=1

# Container Features (für Docker-Support)
LXC_FEATURES=nesting=1,keyctl=1

# DNS Server
LXC_NAMESERVER_1=192.168.1.7
LXC_NAMESERVER_2=
