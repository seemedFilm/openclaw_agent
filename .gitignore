# ============================================================================
# OpenClaw Multi-Agent System .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Sensitive Information
# ----------------------------------------------------------------------------

GITHUB-DEPLOY.md

# Environment files mit Secrets
.env
.env.local
.env.*.local
*.env

# SSH Keys
*.pem
*.key
id_rsa*
id_ed25519*

# API Keys und Tokens
**/secrets/
**/credentials/
**/*secret*
**/*token*
**/*apikey*

# Container Info (enthält IPs)
container-info.txt
container-info.json

# ----------------------------------------------------------------------------
# OpenClaw spezifisch
# ----------------------------------------------------------------------------

# OpenClaw Config mit Secrets
.openclaw/
config.json
agents/*/config.json

# OpenClaw Logs
*.log
logs/
*.log.*

# OpenClaw Cache
.cache/
*.cache

# ----------------------------------------------------------------------------
# Node.js / npm
# ----------------------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----------------------------------------------------------------------------
# Python / Ansible
# ----------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.ansible/

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------

docker-compose.override.yml
.dockerignore

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------

tmp/
temp/
*.tmp
*.bak
*.backup
*.old

# ----------------------------------------------------------------------------
# Proxmox spezifisch
# ----------------------------------------------------------------------------

# Backup Configs
proxmox/backup/
*.backup.sh

# Generated Scripts
**/generated_*

# ----------------------------------------------------------------------------
# Git
# ----------------------------------------------------------------------------

*.orig
*.rej
*.patch

# ----------------------------------------------------------------------------
# Zertifikate
# ----------------------------------------------------------------------------

*.crt
*.cert
*.cer
*.pem
*.p12
*.pfx
ssl/
certs/

# ----------------------------------------------------------------------------
# Traefik
# ----------------------------------------------------------------------------

acme.json
traefik.log

# ----------------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------------

Thumbs.db
.Spotlight-V100
.Trashes
